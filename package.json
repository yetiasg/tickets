{
  "name": "tickets-core-backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "prepare": "husky",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "spellcheck": "cspell .",
    "commitlint": "commitlint --from=HEAD~1 --to=HEAD",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm run typecheck && pnpm run lint && pnpm run test",
    "verify:full": "pnpm run typecheck && pnpm run lint && pnpm run test && pnpm run test:integration && pnpm run spellcheck",
    "infra:up": "docker compose -f compose.yml up -d",
    "infra:down": "docker compose -f compose.yml down",
    "infra:reset": "docker compose -f compose.yml down -v",
    "infra:logs": "docker compose -f compose.yml logs -f",
    "infra:ps": "docker compose -f compose.yml ps",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:integration": "jest --runInBand --config ./test/jest-integration.json"
  },
  "dependencies": {
    "@nestjs/common": "11.1.17",
    "@nestjs/core": "11.1.17",
    "@nestjs/platform-express": "11.1.17",
    "@nestjs/swagger": "11.2.6",
    "@nestjs/throttler": "6.4.0",
    "builder-pattern": "2.2.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.2",
    "drizzle-orm": "0.45.1",
    "fp-ts": "2.16.11",
    "pg": "8.20.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "swagger-ui-express": "5.0.1"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "9.39.4",
    "@nestjs/cli": "11.0.16",
    "@nestjs/schematics": "11.0.9",
    "@nestjs/testing": "11.1.17",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/node": "22.19.15",
    "@types/pg": "8.15.5",
    "@types/supertest": "6.0.3",
    "cspell": "9.7.0",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-unused-imports": "4.2.0",
    "globals": "16.5.0",
    "husky": "9.1.7",
    "jest": "30.3.0",
    "prettier": "3.8.1",
    "source-map-support": "0.5.21",
    "supertest": "7.2.2",
    "testcontainers": "11.13.0",
    "ts-jest": "29.4.6",
    "ts-loader": "9.5.4",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": "test/.*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "src/**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
